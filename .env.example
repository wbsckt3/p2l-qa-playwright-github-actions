# Replicar nombres en GitHub Secrets (ADMIN_EMAIL, ADMIN_PASSWORD) para el workflow.
ADMIN_EMAIL=tugmail@gmail.com
ADMIN_PASSWORD=tu_contraseña_de_gmail
PLAYWRIGHT_STORAGE_STATE=storageState.json

# Opcional (local): JSON de sesión para no repetir login; no es el flujo de CI.
# PLAYWRIGHT_STORAGE_STATE=playwright/.auth/p2l-admin.json

# Si es "1", se omite la UI de Google (requiere storage válido en config).
# PLAYWRIGHT_SKIP_GOOGLE_UI=0

# Si es "1", el E2E no llama a login con Google: solo abre el dashboard (requiere sesión en
# PLAYWRIGHT_STORAGE_STATE o, en GitHub, PLAYWRIGHT_STORAGE_B64; útil en este repo de QA, no en el app).
# PLAYWRIGHT_DASHBOARD_ONLY=0

# En GitHub Actions: use el secreto PLAYWRIGHT_STORAGE_B64; no se hace login Google en el job.

# Sin Chrome instalado, Chromium empaquetado:
# PLAYWRIGHT_USE_CHROMIUM=1
