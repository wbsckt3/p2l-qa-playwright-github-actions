# Valores de referencia: en el flujo principal NO hace falta copiar este archivo en el PC del tester.
# Configure los mismos nombres como Secretos de GitHub (ADMIN_EMAIL, ADMIN_PASSWORD) para el workflow.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Opcional: ruta a un archivo JSON de sesión guardado con Playwright
# (recomendado si Google bloquea login automatizado en CI).
# Ejemplo local tras login manual: playwright/.auth/p2l-admin.json
# PLAYWRIGHT_STORAGE_STATE=playwright/.auth/p2l-admin.json

# Si es "1", el flujo de UI de Google se omite (requiere PLAYWRIGHT_STORAGE_STATE válido).
# PLAYWRIGHT_SKIP_GOOGLE_UI=0
